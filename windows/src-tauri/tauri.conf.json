{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HeySure Device",
  "version": "0.1.0",
  "identifier": "com.heysure.device.win.tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HeySure Agent",
        "width": 1020,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520,
        "visible": false,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "../assets/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
