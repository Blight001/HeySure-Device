# HeySure-Device

# All node_modules
**/node_modules/

# Build outputs per platform
windows/dist/
windows/release/
windows/*.tsbuildinfo

linux/dist/
linux/release/
linux/*.tsbuildinfo

mac/dist/
mac/release/
mac/*.tsbuildinfo

extension/dist/

# Android
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/HeySureAgent-*.apk
android/.idea/
android/captures/
android/*.iml

android-adb/dist/

# Device Python venvs
**/device_runtime/python/.venv/
**/__pycache__/

# Synced files from device/shared (never edit directly)
# These are generated by device/shared/scripts/sync-shared.js
windows/assets/desktop*.png
windows/assets/icon.ico
windows/src/capture-bridge.ts
windows/src/constants.ts
windows/src/executor/
windows/src/ipc/
windows/src/main.ts
windows/src/platform-profile.ts
windows/src/preload.ts
windows/src/renderer/
windows/src/runtime/
windows/src/services/
windows/src/tools/
windows/src/windows/
# (same pattern for linux/ and mac/ — see original root .gitignore for full list)

# General
.DS_Store
*.log
dist/
*.tsbuildinfo
