# HeySure-Device

# All node_modules
**/node_modules/

# Build outputs per platform
windows/dist/
windows/release/
windows/*.tsbuildinfo

linux/dist/
linux/release/
linux/*.tsbuildinfo

mac/dist/
mac/release/
mac/*.tsbuildinfo

extension/dist/

# Android
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/HeySureAgent-*.apk
android/.idea/
android/captures/
android/*.iml

android-adb/dist/

# Device Python venvs (dev)
**/device_runtime/python/.venv/
**/__pycache__/

# Bundled self-contained Python runtime (generated during `npm run package`, very large)
# Shipped inside the installer via extraResources. Do NOT commit.
**/bundled/
windows/bundled/
linux/bundled/
mac/bundled/

# Synced files from device/shared (never edit directly)
# These are generated by device/shared/scripts/sync-shared.js
windows/src/capture-bridge.ts
windows/src/constants.ts
windows/src/executor/
windows/src/ipc/
windows/src/main.ts
windows/src/platform-profile.ts
windows/src/preload.ts
windows/src/renderer/
windows/src/runtime/
windows/src/services/
windows/src/tools/
windows/src/windows/
windows/src/asset-path.ts
linux/src/asset-path.ts
mac/src/asset-path.ts
# (same pattern for linux/ and mac/ — see original root .gitignore for full list)

# windows-tauri (Tauri prototype) also reuses subset via sync-shared.js
windows-tauri/src/constants.ts
windows-tauri/src/server-url.ts
windows-tauri/src/executor/catalog.ts
windows-tauri/src/runtime/permission-guard.ts

# Note: desktop shell assets/icons are now maintained per-platform (no longer
# synced from shared/assets which has been removed). 
# windows/assets/, linux/assets/, mac/assets/ and windows-tauri/src-tauri/icons/
# may be committed directly if they contain shell-specific or required binaries.


# General
.DS_Store
*.log
dist/
*.tsbuildinfo
