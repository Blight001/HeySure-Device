# HeySure-Device

# All node_modules
**/node_modules/

# Build outputs per platform
windows/dist/
windows/release/
windows/*.tsbuildinfo

linux/dist/
linux/release/
linux/*.tsbuildinfo

mac/dist/
mac/release/
mac/*.tsbuildinfo

extension/dist/

# Android
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/HeySureAgent-*.apk
android/.idea/
android/captures/
android/*.iml

android-adb/dist/

# Device Python venvs (dev)
**/device_runtime/python/.venv/
**/__pycache__/

# Bundled self-contained Python runtime (generated during `npm run package`, very large)
# Shipped inside the installer via extraResources. Do NOT commit.
**/bundled/
windows/bundled/
linux/bundled/
mac/bundled/

# Synced files from device/shared (never edit directly)
# These are generated by device/shared/scripts/sync-shared.js
# NOTE: windows/ is now the Tauri desktop app (migrated from the old Electron
# shell). Its src/ files are real, tracked source — do NOT ignore them.
linux/src/asset-path.ts
mac/src/asset-path.ts
# (same pattern for linux/ and mac/ — see original root .gitignore for full list)

# Note: desktop shell assets/icons are now maintained per-platform (no longer
# synced from shared/assets which has been removed).
# windows/assets/, linux/assets/, mac/assets/ and windows/src-tauri/icons/
# may be committed directly if they contain shell-specific or required binaries.


# General
.DS_Store
*.log
dist/
*.tsbuildinfo
