# HeySure Linux 服务器端 agent 配置（复制为 .env 后填写）
# 凭据一律走环境变量，不要硬编码到代码里（read.md 0.3）。

# ── 必填 ─────────────────────────────────────────────────────────────
# HeySure API Gateway 地址（对外唯一入口，默认 3000 端口）
HEYSURE_SERVER=http://49.234.181.190:3000
# 与网页控制台同一账号，本服务归属该用户
HEYSURE_ACCOUNT=heysure
HEYSURE_PASSWORD=heysure

# ── 可选 ─────────────────────────────────────────────────────────────
# 逻辑 ID：稳定唯一，重启/重连必须不变（不填自动用 linux-<主机名>-<machine-id>）
# HEYSURE_SERVICE_ID=my-centos-01
# 网页面板与 AI 看到的展示名（不填自动用「Linux 服务器 (<主机名>)」）
# HEYSURE_SERVICE_NAME=生产 CentOS 服务器

# 命令行远程（rt:*）：真人在网页控制台直接操作本机 shell，默认开启
# HEYSURE_ENABLE_REMOTE_TERMINAL=true
# 通用 shell.exec 工具（让 AI 执行任意命令，危险）：默认开启；设 false 变纯只读画像
# HEYSURE_ENABLE_SHELL_EXEC=true
# 持久化交互式控制台 console.*（让 AI 能应付安装程序的 [Y/n] 确认、选菜单等）：默认开启
# HEYSURE_ENABLE_CONSOLE=true
# PTY / shell.exec 默认使用的 shell（不填自动探测 bash→sh）
# HEYSURE_SHELL=/bin/bash

# 设备图标："1".."8" 预置编号 / "/device_png/N.webp" / 绝对 URL（不填走网页默认）
# HEYSURE_ICON=3

# 日志级别 DEBUG/INFO/WARNING
# LOG_LEVEL=INFO
